# Copy to .env and adjust for local development.
# Docker Compose reads these automatically.

DATABASE_URL=postgresql+psycopg2://acme:acme@db:5432/acmeparts

# Seed control
SEED=42
MESSINESS=medium   # clean | medium | chaos

# Optional scale controls
PARTS_COUNT=5000
SUPPLIERS_COUNT=400
USERS_COUNT=150
REVISION_PARTS_COUNT=3000
CHANGE_ORDERS_COUNT=20000
PURCHASE_ORDERS_COUNT=30000
AUDIT_LOG_COUNT=200000
